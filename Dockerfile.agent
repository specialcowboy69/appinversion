FROM python:3.10-slim

# Install system dependencies for Docling and machine learning
RUN apt-get update && apt-get install -y \
    build-essential \
    libgomp1 \
    libgl1 \
    libglib2.0-0 \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Set PYTHONPATH so Python can find the 'app' module
ENV PYTHONPATH=/app

# Copy requirements and install
COPY investment-ai-agent/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the entire agent folder
COPY investment-ai-agent/ .

# Expose the port for the FastAPI server
EXPOSE 8000

CMD ["python", "-m", "app.main"]
