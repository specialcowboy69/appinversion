FROM python:3.10-slim

# Install system dependencies for Docling and machine learning
RUN apt-get update && apt-get install -y \
    build-essential \
    libgomp1 \
    libgl1-mesa-glx \
    libglib2.0-0 \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy requirements from the specific folder
COPY investment-ai-agent/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the rest of the agent code
COPY investment-ai-agent/ .

# Expose the port if your agent has an API (e.g., FastAPI)
# EXPOSE 8000

CMD ["python", "app/main.py"] 
